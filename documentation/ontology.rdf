    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#numberOfParkingSpots -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#numberOfParkingSpots">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByPermitType"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByVehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of parking spots. Can be used to represent the total number of spots, or the  number of spots by vehicle type or by permit type. For example, 50 spots for cars, 10 for motorcycles.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de plazas de aparcamiento. Se puede usar para representar el número total de plazas, o el número de plazas por tipo de vehículo o por tipo de permiso. Por ejemplo, 50 plazas para coches y 10 para motos.</rdfs:comment>
        <rdfs:label xml:lang="en">number of parking spots</rdfs:label>
        <rdfs:label xml:lang="es">número de plazas de aparcamiento</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
        <rdfs:comment xml:lang="en">Public road zone where parking is subject to time regulation, fee payment, or other restrictions.</rdfs:comment>
        <rdfs:comment xml:lang="es">Zona de la vía pública donde el estacionamiento está sujeto a regulación horaria, pago de tasas u otras restricciones.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulated parking zone</rdfs:label>
        <rdfs:label xml:lang="es">Zona de estacionamiento regulado</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone">
        <rdfs:comment xml:lang="es">Area a la que se aplica una regulacion o normativa particular.</rdfs:comment>
        <rdfs:comment xml:lang="en">Area to which a particular regulation or policy applies.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulated zone</rdfs:label>
        <rdfs:label xml:lang="es">Zona regulatoria</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#OffStreetParking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#OffStreetParking">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking"/>
        <rdfs:comment xml:lang="es">Aparcamiento fuera de la vía pública. Incluye instalaciones o superficies de aparcamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Off-street parking, including parking facilities or parking surfaces.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento fuera de la vía pública</rdfs:label>
        <rdfs:label xml:lang="en">Off-street parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#OnStreetParking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#OnStreetParking">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking"/>
        <rdfs:comment xml:lang="es">Aparcamiento en la vía pública que inluye plazas para residentes, no residentes, libres, carga y descarga, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">On-street parking that includes spaces for residents, non-residents, free spaces, loading and unloading, among others.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento en la vía pública</rdfs:label>
        <rdfs:label xml:lang="en">On-street parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:comment xml:lang="es">Aparcamiento para diferentes tipos de vehículo que incluye instalaciones o superficies de aparcamiento fuera de la vía pública o zonas de aparcamiento en la vía pública para residentes, no residentes o libres.</rdfs:comment>
        <rdfs:comment xml:lang="en">Parking for different types of vehicles, including off-street parking facilities or on-street parking zones for residents, non-residents, or free parking.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento</rdfs:label>
        <rdfs:label xml:lang="en">Parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingFee -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingFee">
        <rdfs:comment xml:lang="en">Parking fee that essentially covers the right to park the vehicle in an authorized space for a certain time period.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tarifa de un aparcamiento que cubre fundamentalmente el derecho a estacionar el vehículo en un espacio autorizado durante un tiempo determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">Parking fee</rdfs:label>
        <rdfs:label xml:lang="es">Tarifa</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpot -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpot">
        <rdfs:comment xml:lang="en">Individual parking spot in an on-street or off-street parking.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plaza individual de estacionamiento dentro o fuera de la vía pública.</rdfs:comment>
        <rdfs:label xml:lang="en">Parking spot</rdfs:label>
        <rdfs:label xml:lang="es">Plaza (de aparcamiento)</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByPermitType -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByPermitType">
        <rdfs:comment xml:lang="en">Group of parking spots for each type of permit, for example Resident. It indicates the number of slots  for each type.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo de plazas por cada tipo de permiso, por ejemplo Residente. Indica el número de plazas por cada tipo.</rdfs:comment>
        <rdfs:label xml:lang="en">Group of parking spots by type of permit</rdfs:label>
        <rdfs:label xml:lang="es">Grupo de plazas por tipo de permiso</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByVehicleType -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByVehicleType">
        <rdfs:comment xml:lang="en">Group of parking spots for each type of vehicle: cars, motorcycles, bicycles, among others. It indicates the number of slots per type.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo de plazas de aparcamiento para cada tipo de vehículo: coches, motocicletas, biciletas, entre otros. Indica el número de plazas por tipo.</rdfs:comment>
        <rdfs:label xml:lang="en">Group of parking spots by vehicle type</rdfs:label>
        <rdfs:label xml:lang="es">Grupo de plazas por tipo de vehículo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility">
        <rdfs:comment xml:lang="es">Equipamientos a los que un ciudadano puede acudir pertenecientes a una organización pública o privadal. Un equipamiento puede ser un aparcamiento, un centro educativo, una estación de bicicleta compartida y cualquier instalación que sea un centro de salud, centro educativo, centro social, comisaría, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Facilities that citizens can access and that belong to public or private organizations. A facility can be a parking lot, an educational center, a bike-sharing station, or any facility that serves as a health center, educational center, community center, police station, among others.</rdfs:comment>
        <rdfs:label xml:lang="es">Equipamiento</rdfs:label>
        <rdfs:label xml:lang="en">Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">Points where access or counting observations can be made using sensors.</rdfs:comment>
        <rdfs:comment xml:lang="es">Puntos en donde se pueden realizar observaciones de acceso o de conteo a través de sensores.</rdfs:comment>
        <rdfs:label xml:lang="en">Observation point</rdfs:label>
        <rdfs:label xml:lang="es">Punto de observación</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:comment xml:lang="es">Esta clase representa el tipo &quot;feature&quot; de nivel superior. Es equivalente a GFI_Feature, definida en la norma ISO 19156:2011, y es la superclase de todos los tipos de &quot;feature&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
    </owl:Class>
    


