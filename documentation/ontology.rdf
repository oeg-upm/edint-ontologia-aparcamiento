    <!-- http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#permitType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#permitType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByVehicleType"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/PermitType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relación entre el Grupo de plazas por tipo de permiso y la taxonomía de tipos de permiso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the group of places by type of permit and the taxonomy of types of permit.</rdfs:comment>
        <rdfs:label xml:lang="en">permit type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de permiso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#vehicleType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#vehicleType">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/VehicleType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Tipo de vehículo. Los valores son conceptos SKOS que pertenecen a una lista controlada de tipos de vehículo (por ejemplo, turismo, furgoneta, caravana, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="es">Type of vehicle. The range is a SKOS concept that belongs to a controlled list of permit types (e.g., van, truck, caravan, etc.).</rdfs:comment>
        <rdfs:label xml:lang="es">tipo de vehiculo</rdfs:label>
        <rdfs:label xml:lang="en">vehicle type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasParkingFee -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasParkingFee">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingFee"/>
        <rdfs:comment xml:lang="es">Relación entre un aparcamiento y su tarifa.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between a parking and its fee.</rdfs:comment>
        <rdfs:label xml:lang="en">has parking fee</rdfs:label>
        <rdfs:label xml:lang="es">tiene tarifa de aparcamiento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasParkingSpot -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasParkingSpot">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByPermitType"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByVehicleType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpot"/>
        <rdfs:comment xml:lang="es">Relación entre el aparcamiento o el grupo de plazas de un aparcamiento y las plazas específicas que contiene.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between  the parking or a group of parking spots and the specific spots it contains.</rdfs:comment>
        <rdfs:label xml:lang="en">has parking spot</rdfs:label>
        <rdfs:label xml:lang="es">tiene plaza de aparcamiento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasSensor -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasSensor">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint"/>
        <rdfs:comment xml:lang="es">Relación ente el punto de observación y el sensor que realiza la observación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the observation point and the sensor that performs the observation.</rdfs:comment>
        <rdfs:label xml:lang="en">has sensor</rdfs:label>
        <rdfs:label xml:lang="es">tiene sensor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasSpotsByParkingPermitType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasSpotsByParkingPermitType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByPermitType"/>
        <rdfs:comment xml:lang="es">Relación entre el Aparcamiento y su Grupo de plazas por tipo de permiso, por ejemplo Plazas de Rotación, Residentes, Movilidad Reducida, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the Parking and its Group of spaces by type of permit, for example Rotation Spaces, Residents, Reduced Mobility, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">has a group of spots per type of permit</rdfs:label>
        <rdfs:label xml:lang="es">tiene grupo de plazas por tipo de permiso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasSpotsByVehicleType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#hasSpotsByVehicleType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#ParkingSpotsByVehicleType"/>
        <rdfs:comment xml:lang="es">Relación entre el Aparcamiento y  su Grupo de plazas por tipo de vehículo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the Parking and its Group of spots by vehicle type.</rdfs:comment>
        <rdfs:label xml:lang="en">has a group of spots per type of vehicle</rdfs:label>
        <rdfs:label xml:lang="es">tiene grupo de plazas por tipo de vehiculo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#isPartOfZone -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#isPartOfZone">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#OnStreetParking"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone"/>
        <rdfs:comment xml:lang="es">Relación entre un grupo de plazas de aparcamiento en la vía pública y la zona de estacionamiento regulado a la cual pertenecen.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between a group of parking spaces on a street and the regulated parking zone to which they belong.</rdfs:comment>
        <rdfs:label xml:lang="es">es parte de zona</rdfs:label>
        <rdfs:label xml:lang="en">is part of zone</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#providesPublicService -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#providesPublicService">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:comment xml:lang="en">Public service provided by a municipal facility, for example internet via wifi.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio público prestado por un equipamiento municipal, por ejemplo internet a través de una wifi.</rdfs:comment>
        <rdfs:label xml:lang="es">presta servicio público</rdfs:label>
        <rdfs:label xml:lang="en">provides public service</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasObservationPoint -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasObservationPoint">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint"/>
        <rdfs:comment xml:lang="es">Relación entre un elemento de la infraestructura y un punto de observación por algún sensor.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an infrastructure element and an observation point by some sensor.</rdfs:comment>
        <rdfs:label xml:lang="en">has observation point</rdfs:label>
        <rdfs:label xml:lang="es">tiene punto de observación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


