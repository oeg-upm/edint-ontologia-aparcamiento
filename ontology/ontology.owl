    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>edintzone:RegulatedParkingZone</AbbreviatedIRI>
        <Literal xml:lang="en">Public road zone where parking is subject to time regulation, fee payment, or other restrictions.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>edintzone:RegulatedParkingZone</AbbreviatedIRI>
        <Literal xml:lang="es">Zona de la vía pública donde el estacionamiento está sujeto a regulación horaria, pago de tasas u otras restricciones.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>edintzone:RegulatedParkingZone</AbbreviatedIRI>
        <Literal xml:lang="en">Regulated parking zone</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>edintzone:RegulatedParkingZone</AbbreviatedIRI>
        <Literal xml:lang="es">Zona de estacionamiento regulado</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>edintzone:RegulatedZone</AbbreviatedIRI>
        <Literal xml:lang="es">Area a la que se aplica una regulacion o normativa particular.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>edintzone:RegulatedZone</AbbreviatedIRI>
        <Literal xml:lang="en">Area to which a particular regulation or policy applies.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>edintzone:RegulatedZone</AbbreviatedIRI>
